@inject AuthService AuthService
@inject NavigationManager Nav
@implements IDisposable
<header class="topnav">
    <div class="topnav-inner">
        <a class="topnav-brand" href="/">Henry Brooks</a>

        <button class="topnav-toggle"
                @onclick="ToggleMenu"
                aria-label="Toggle navigation menu"
                aria-expanded="@_menuOpen"
                aria-controls="main-nav">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <nav id="main-nav"
             class="topnav-links @(_menuOpen ? "open" : "")"
             role="navigation"
             aria-label="Main navigation">

            <NavLink href="" Match="NavLinkMatch.All">
                <span class="nav-icon icon-home" aria-hidden="true"></span>
                <span>Home</span>
            </NavLink>

            <NavLink href="league-archive">
                <span class="nav-icon icon-league" aria-hidden="true"></span>
                <span>League</span>
            </NavLink>

            <NavLink href="privacy">
                <span class="nav-icon icon-privacy" aria-hidden="true"></span>
                <span>Privacy</span>
            </NavLink>

            @if (_isAuthenticated)
            {
                <div class="topnav-divider" role="separator"></div>

                <NavLink href="admin/league-archive">
                    <span class="nav-icon icon-admin" aria-hidden="true"></span>
                    <span>League Admin</span>
                </NavLink>

                <button class="topnav-logout" @onclick="HandleLogout">
                    <span class="nav-icon icon-logout" aria-hidden="true"></span>
                    <span>Logout</span>
                </button>
            }
        </nav>
    </div>
</header>

@code {
    private bool _menuOpen = false;
    private bool _isAuthenticated = false;

    protected override async Task OnInitializedAsync()
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        Nav.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        _menuOpen = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        _isAuthenticated = false;
        _menuOpen = false;
        await InvokeAsync(StateHasChanged);
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}